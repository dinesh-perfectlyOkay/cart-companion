{
  "manifest_version": 3,
  "name": "CouponSnap",
  "version": "1.0.0",
  "description": "Automatically find and apply coupon codes at checkout",
  "action": {
    "default_popup": "index.html",
    "default_icon": "favicon.ico"
  },
  "permissions": ["activeTab", "storage"],
  "icons": {
    "16": "favicon.ico",
    "48": "favicon.ico",
    "128": "favicon.ico"
  }
}